{
  "name": "@ki-assistent/root",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern 'apps/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}' 'scripts/**/*.ts'",
    "test": "vitest run",
    "audit-deps": "tsx scripts/audit-deps.ts",
    "dev:desktop": "pnpm --filter @ki-assistent/desktop dev",
    "dev:gateway": "pnpm --filter @ki-assistent/gateway dev",
    "dev:relay": "pnpm --filter @ki-assistent/relay dev",
    "build:desktop": "pnpm --filter @ki-assistent/desktop build",
    "build:mobile": "pnpm --filter @ki-assistent/mobile build",
    "build:installer": "bash scripts/prepare-gateway.sh && pnpm --filter @ki-assistent/desktop build && pnpm --filter @ki-assistent/desktop build:installer",
    "harness:risk-tier": "tsx scripts/risk-policy-gate.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "sharp",
      "tesseract.js"
    ],
    "overrides": {
      "react-server-dom-webpack": ">=19.0.2"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^3.0.1",
    "libsodium-wrappers": "^0.8.2",
    "picomatch": "^4.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0"
  }
}
