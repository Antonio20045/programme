{
  "name": "@ki-assistent/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "predev": "pnpm -C ../../packages/gateway exec tsdown --no-clean",
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "ELECTRON_RUN_AS_NODE= electron-vite build",
    "build:installer": "electron-builder --config electron-builder.yml",
    "build:installer:mac": "electron-builder --config electron-builder.yml --mac",
    "build:installer:win": "electron-builder --config electron-builder.yml --win",
    "build:installer:linux": "electron-builder --config electron-builder.yml --linux",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@ki-assistent/shared": "workspace:*",
    "@ki-assistent/tools": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.0.0",
    "framer-motion": "^12.34.4",
    "qrcode": "^1.5.0",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@clerk/clerk-react": "^5.60.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
