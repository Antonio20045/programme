# ===========================================================================
# KI-Assistent — Environment Variables
# Copy to .env and fill in your values:  cp docker/env-example .env
# ===========================================================================

# --- LLM Provider (mindestens einer) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me-to-a-secure-password
# DATABASE_URL is auto-constructed in docker-compose.yml.
# For standalone/Railway use: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# --- Gateway Auth ---
# OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-string

# --- Encryption (AES-256-GCM for OAuth tokens in DB) ---
# 64 hex chars = 32 bytes. Generate: openssl rand -hex 32
# TOKEN_ENCRYPTION_KEY=

# --- Clerk (optional — without Clerk the gateway runs in local mode) ---
# CLERK_SECRET_KEY=sk_...
# CLERK_WEBHOOK_SECRET=whsec_...

# --- Stripe (optional — only for billing) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Google OAuth (optional — only for Gmail/Calendar tools) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# --- Docker Compose Overrides ---
# GATEWAY_BIND=lan
# GATEWAY_PORT=18789
